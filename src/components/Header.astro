---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
];
---

<header class="bg-white border-b border-[#d0d7de] sticky top-0 z-50">
  <nav class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-14 items-center">
      <a href="/" class="text-sm font-semibold text-[#24292f] hover:text-[#0969da] transition-colors">
        Lazy Software Developer
      </a>
      <div class="flex space-x-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm text-[#57606a] hover:text-[#24292f] transition-colors"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>
