---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
];
---

<header class="bg-white border-b border-gray-200">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <div class="flex items-center">
        <a href="/" class="text-xl font-bold text-gray-900 hover:text-gray-700 transition-colors">
          LazyProductDeveloper
        </a>
      </div>
      <div class="flex space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-gray-600 hover:text-gray-900 transition-colors font-medium"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>
