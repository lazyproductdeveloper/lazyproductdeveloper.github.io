---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const projectLink = 'https://hytaletools.io';
const projectName = 'Hytale Tools';
---

<Layout
  title="Hytale Tools - Lazy Software Developer"
  description="An all-in-one data powerhouse for the Hytale community."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <a href="/" class="text-sm text-[#57606a] hover:text-[#0969da] mb-8 inline-flex items-center">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </a>

    <article>
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-[#24292f] mb-4">Hytale Tools</h1>
        <p class="text-lg text-[#57606a] leading-relaxed mb-6">
          An all-in-one data powerhouse for the Hytale community. I got tired of searching for item stats manually, so I built a database to do it for me.
        </p>
        <a
          href={projectLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-4 py-2 bg-[#0969da] text-white text-sm font-medium rounded-md hover:bg-[#085bb8] transition-colors"
        >
          Visit {projectName}
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </header>

      <div class="border-t border-[#d0d7de] pt-8">
        <section class="mb-8">
          <h2 class="text-xl font-semibold text-[#24292f] mb-3">Why I Built This</h2>
          <p class="text-[#57606a] leading-relaxed">
            As a Hytale player, I found myself constantly looking up item stats, crafting recipes, and drop rates across multiple sources. It was time-consuming and frustrating. So I decided to build a comprehensive database that puts all this information in one place.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-xl font-semibold text-[#24292f] mb-3">Features</h2>
          <ul class="space-y-2 text-[#57606a]">
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Complete item stats database
            </li>
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Crafting recipes
            </li>
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Drop rates and sources
            </li>
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Search and filter functionality
            </li>
            <li class="flex items-start">
              <span class="text-[#0969da] mr-2">•</span>
              Regular updates as new content releases
            </li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-xl font-semibold text-[#24292f] mb-3">Tech Stack</h2>
          <p class="text-[#57606a] leading-relaxed">
            Built with modern web technologies to ensure fast load times and a smooth user experience.
          </p>
        </section>
      </div>
    </article>
  </main>

  <footer class="border-t border-[#d0d7de] mt-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-[#57606a] text-sm">
        © {new Date().getFullYear()} Lazy Software Developer
      </p>
    </div>
  </footer>
</Layout>
