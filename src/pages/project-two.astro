---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Project Two - LazyProductDeveloper">
  <Header />
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a
      href="/"
      class="inline-flex items-center text-gray-600 hover:text-gray-900 mb-8 transition-colors"
    >
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Home
    </a>

    <article>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Project Two</h1>
      <div class="flex gap-2 mb-8">
        <span class="px-3 py-1 text-sm font-medium bg-green-100 text-green-700 rounded-full">Mobile</span>
        <span class="px-3 py-1 text-sm font-medium bg-gray-100 text-gray-700 rounded-full">React Native</span>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <p>
          This is another sample project page. Replace this content with your actual project details.
        </p>
        <p>
          You can add screenshots, features, tech stack, links to app stores, and more.
        </p>
      </div>
    </article>
  </main>

  <footer class="border-t border-gray-200 mt-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-gray-500 text-sm">
        &copy; {new Date().getFullYear()} LazyProductDeveloper. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>
