---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const projects = [
  {
    title: 'Hytale Tools',
    description: 'An all-in-one data powerhouse for the Hytale community.',
    href: '/hytaletools',
    link: 'https://hytaletools.io',
  },
  {
    title: 'Kingdom of Marionettes Online',
    description: 'A website about the game Kingdom of Marionettes, with link to online demo.',
    href: '/kingdom-of-marionettes',
    link: 'https://kingdomofmarionettes.online',
  },
  {
    title: 'Zombies and Luig',
    description: 'A website about the game Zombies and Luig, with itch.io game and tips.',
    href: '/zombies-and-luig',
    link: 'https://zombiesandluig.com',
  },
];
---

<Layout
  title="Lazy Software Developer"
  description="Hi there, I'm a Lazy Software Developer"
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <section class="mb-12">
      <h1 class="text-3xl font-bold text-[#24292f] mb-4">
        Hi there, I'm a Lazy Software Developer
      </h1>
      <p class="text-[#57606a] text-lg leading-relaxed">
        They say "pick a lazy person to do a hard job because they will find an easy way to do it." That's me. I build tools so I can spend more time doing... well, nothing.
      </p>
    </section>

    <section>
      <h2 class="text-xl font-semibold text-[#24292f] mb-6">What I'm Building</h2>
      <div class="space-y-4">
        {projects.map((project) => (
          <div class="block p-4 border border-[#d0d7de] rounded-lg hover:border-[#0969da] hover:bg-[#f6f8fa] transition-all">
            <div class="flex items-center justify-between">
              <a href={project.href} class="flex-1">
                <h3 class="font-semibold text-[#24292f]">{project.title}</h3>
                <p class="text-sm text-[#57606a] mt-1">{project.description}</p>
              </a>
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[#0969da] text-sm hover:underline whitespace-nowrap"
              >
                Visit →
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <footer class="border-t border-[#d0d7de] mt-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-[#57606a] text-sm">
        © {new Date().getFullYear()} Lazy Software Developer
      </p>
    </div>
  </footer>
</Layout>
