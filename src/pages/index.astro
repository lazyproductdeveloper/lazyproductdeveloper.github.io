---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const projects = [
  {
    title: 'Project One',
    description: 'A sample project showcasing web development capabilities.',
    href: '/project-one',
    tags: ['Web', 'React'],
  },
  {
    title: 'Project Two',
    description: 'Another amazing project built with modern technologies.',
    href: '/project-two',
    tags: ['Mobile', 'React Native'],
  },
];
---

<Layout title="LazyProductDeveloper - Project Showcase">
  <Header />
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        Welcome to My Project Showcase
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Explore my collection of projects and experiments in software development.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <a
          href={project.href}
          class="block p-6 bg-white rounded-lg border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all"
        >
          <h2 class="text-xl font-semibold text-gray-900 mb-2">
            {project.title}
          </h2>
          <p class="text-gray-600 mb-4">
            {project.description}
          </p>
          <div class="flex gap-2">
            {project.tags.map((tag) => (
              <span class="px-2 py-1 text-xs font-medium bg-gray-100 text-gray-600 rounded">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-gray-200 mt-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-gray-500 text-sm">
        &copy; {new Date().getFullYear()} LazyProductDeveloper. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>
